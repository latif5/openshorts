# Frontend dashboard — use when deploying from repo root (Root Directory = /).
# Zeabur auto-matches this file when the service is named "dashboard".
FROM node:18-alpine

WORKDIR /app

COPY dashboard/package.json dashboard/package-lock.json* ./

RUN npm install

COPY dashboard/ ./

# Zeabur may use the Root Directory path (/dashboard) as the container entrypoint.
COPY dashboard/zeabur-entrypoint.sh /dashboard
RUN chmod +x /dashboard

EXPOSE 5173

CMD ["/dashboard"]
